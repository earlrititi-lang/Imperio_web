---
import CollectionCard from "../components/CollectionCard.astro";
import PageShell from "../layouts/PageShell.astro";
import { getCollection } from "astro:content";
import { sortEntriesByDateDesc } from "../utils/content";

const list = sortEntriesByDateDesc(await getCollection("articles")).filter(
  (entry) => entry.data.category === "efemeride"
);
---

<PageShell
  title="Efemerides"
  description="Efemerides semanales: memoria viva sin ruido."
  eyebrow="Efemerides"
  heading="Memoria activa"
  summary="Textos breves para situar el presente desde el archivo."
>
  <section class="section">
    <div class="grid">
      {list.map((entry) => (
        <CollectionCard
          meta={entry.data.date}
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/biblioteca/${entry.id}`}
          ctaLabel="Leer"
        />
      ))}
    </div>
  </section>
</PageShell>
