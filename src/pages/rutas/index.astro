---
import CollectionCard from "../../components/CollectionCard.astro";
import PageShell from "../../layouts/PageShell.astro";
import { getCollection } from "astro:content";

const rutas = await getCollection("rutas");
---

<PageShell
  title="Rutas"
  description="Rutas tematicas para navegar el archivo."
  eyebrow="Rutas"
  heading="Rutas tematicas"
  summary="Lecturas guiadas para recorrer el archivo sin perder el hilo."
  narrow
>
  <div slot="header" class="grid">
    {rutas.map((ruta) => (
      <CollectionCard
        title={ruta.data.title}
        summary={ruta.data.summary}
        href={`/rutas/${ruta.slug}`}
        ctaLabel="Ver ruta"
      />
    ))}
  </div>
</PageShell>
