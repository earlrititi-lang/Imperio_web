---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Suscripcion | Imperioes"
  description="Gestiona tu suscripcion."
>
  <div class="container">
    <section class="section content">
      <span class="pill">Suscripcion</span>
      <h1>Tu nivel</h1>
      <p class="muted">ASUNCION: integracion Stripe/Members en Sprint 3.</p>
      <div class="grid">
        <div class="card">
          <h3>Estado</h3>
          <p>Rodelero / Piquero / Arcabucero.</p>
        </div>
        <div class="card">
          <h3>Facturacion</h3>
          <p>Metodo y facturas.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>

