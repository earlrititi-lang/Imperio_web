---
import CollectionCard from "../components/CollectionCard.astro";
import PageShell from "../layouts/PageShell.astro";
import { getCollection } from "astro:content";
import { sortEntriesByDateDesc } from "../utils/content";

const list = sortEntriesByDateDesc(await getCollection("articles")).filter(
  (entry) => entry.data.category === "ensayo"
);
---

<PageShell
  title="Ensayos"
  description="Ensayos sobrios para comprender sin ideologia."
  eyebrow="Ensayos"
  heading="Lecturas largas"
  summary="Analisis en profundidad con ritmo semanal."
>
  <section class="section">
    <div class="grid">
      {list.map((entry) => (
        <CollectionCard
          meta={entry.data.date}
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/biblioteca/${entry.slug}`}
          ctaLabel="Leer"
        />
      ))}
    </div>
  </section>
</PageShell>
