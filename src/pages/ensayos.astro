---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const entries = await getCollection("articles");
const list = entries
  .filter((entry) => entry.data.category === "ensayo")
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout
  title="Ensayos | Imperioes"
  description="Ensayos sobrios para comprender sin ideologia."
>
  <div class="container">
    <section class="section">
      <span class="pill">Ensayos</span>
      <h1>Lecturas largas</h1>
      <p>Analisis en profundidad con ritmo semanal.</p>
    </section>
    <section class="section">
      <div class="grid">
        {list.map((entry) => (
          <article class="card">
            <p class="muted">{entry.data.date}</p>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
            <a class="btn btn-ghost" href={`/biblioteca/${entry.slug}`}>Leer</a>
          </article>
        ))}
      </div>
    </section>
  </div>
</Layout>

