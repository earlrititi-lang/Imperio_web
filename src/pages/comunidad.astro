---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Comunidad | Imperioes"
  description="Discord como centro. Debate sobrio y preguntas abiertas."
>
  <div class="container">
    <section class="section content">
      <span class="pill">Comunidad</span>
      <h1>Discord como plaza</h1>
      <p>
        La comunidad vive en Discord. La web sostiene el archivo, las rutas y los
        comentarios para miembros.
      </p>
      <div class="grid">
        <div class="card">
          <h3>Debate sobrio</h3>
          <p>Preguntas abiertas, sin ideologia, con metodo.</p>
        </div>
        <div class="card">
          <h3>Rutas guiadas</h3>
          <p>Lecturas semanales con contexto y mapa de archivo.</p>
        </div>
      </div>
      <div class="section">
        <a class="btn btn-primary" href="/cuenta">Acceder</a>
      </div>
    </section>
  </div>
</Layout>

