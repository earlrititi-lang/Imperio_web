---
import PageShell from "../layouts/PageShell.astro";
---

<PageShell
  title="Comunidad"
  description="Discord como centro. Debate sobrio y preguntas abiertas."
  eyebrow="Comunidad"
  heading="Discord como plaza"
  summary="La comunidad vive en Discord. La web sostiene el archivo, las rutas y los comentarios para miembros."
>
  <Fragment slot="header">
    <div class="grid">
      <div class="card">
        <h3>Debate sobrio</h3>
        <p>Preguntas abiertas, sin ideologia, con metodo.</p>
      </div>
      <div class="card">
        <h3>Rutas guiadas</h3>
        <p>Lecturas semanales con contexto y mapa de archivo.</p>
      </div>
    </div>
    <a class="btn btn-primary" href="/cuenta">Acceder</a>
  </Fragment>
</PageShell>
