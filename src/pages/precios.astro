---
import PageShell from "../layouts/PageShell.astro";
---

<PageShell
  title="Precios"
  description="Escalera de acceso: Gratis, Rodelero, Piquero y Arcabucero por invitacion."
  eyebrow="Escalera editorial"
  heading="Elige tu nivel de acceso"
  summary="La entrada es gratuita. El archivo completo y la comunidad se abren por capas, sin empujar mas de la cuenta."
>
  <section class="section">
    <div class="grid">
      <div class="card">
        <h2>Gratis</h2>
        <p class="muted">Para conocer el ritmo y el tono.</p>
        <p>Manifiesto y adelantos editoriales.</p>
        <a class="btn btn-ghost" href="/manifiesto">Leer manifiesto</a>
      </div>
      <div class="card">
        <h2>Rodelero - 3 EUR</h2>
        <p class="muted">Participacion + 1 premium semanal.</p>
        <p>Acceso a comentarios y comunidad, sin archivo.</p>
        <a class="btn btn-primary" href="/cuenta">Unirme</a>
      </div>
      <div class="card">
        <h2>Piquero - 5 EUR</h2>
        <p class="muted">Archivo completo y herramientas.</p>
        <p>Buscador, rutas, 3/semana + dossier mensual.</p>
        <a class="btn btn-primary" href="/cuenta">Elegir Piquero</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="hero-card">
      <h3>Arcabucero - 9 EUR</h3>
      <p class="muted">
        Arsenal, cuaderno, taller de libro y perks en drops. Solo por triggers.
      </p>
      <p>
        No se promociona en portada. Se desbloquea cuando tu recorrido lo pide.
      </p>
    </div>
  </section>
</PageShell>
