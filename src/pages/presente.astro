---
import CollectionCard from "../components/CollectionCard.astro";
import PageShell from "../layouts/PageShell.astro";
import { getCollection } from "astro:content";
import { sortEntriesByDateDesc } from "../utils/content";

const list = sortEntriesByDateDesc(await getCollection("articles")).filter(
  (entry) => entry.data.category === "presente"
);
---

<PageShell
  title="Presente"
  description="Conectado al presente sin ruido."
  eyebrow="Presente"
  heading="Conectar memoria y ahora"
  summary="Analisis del presente con contexto historico."
>
  <section class="section">
    <div class="grid">
      {list.map((entry) => (
        <CollectionCard
          meta={entry.data.date}
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/biblioteca/${entry.id}`}
          ctaLabel="Leer"
        />
      ))}
    </div>
  </section>
</PageShell>
