---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Login | Imperioes"
  description="Accede a tu cuenta de Imperioes."
>
  <div class="container">
    <section class="section content">
      <span class="pill">Acceso</span>
      <h1>Iniciar sesion</h1>
      <p class="muted">ASUNCION: formulario real conectado en Sprint 3.</p>
      <div class="card">
        <p>Introduce tu email para recibir enlace magico.</p>
        <a class="btn btn-primary" href="/contacto">Solicitar acceso</a>
      </div>
    </section>
  </div>
</Layout>

