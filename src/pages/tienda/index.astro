---
import CollectionCard from "../../components/CollectionCard.astro";
import PageShell from "../../layouts/PageShell.astro";
import { getCollection } from "astro:content";
import { sortEntriesByDateDesc } from "../../utils/content";

const sorted = sortEntriesByDateDesc(await getCollection("drops"));
---

<PageShell
  title="Tienda"
  description="Drops editoriales de tirada corta y piezas de archivo."
  eyebrow="Tienda"
  heading="Drops editoriales"
  summary="Tiradas cortas, calidad sobria, sin ruido. Checkout seguro con Stripe."
>
  <section class="section">
    <div class="grid">
      {sorted.map((entry) => (
        <CollectionCard
          meta={`${entry.data.status} - ${entry.data.date}`}
          title={entry.data.title}
          summary={entry.data.summary}
          href={`/tienda/${entry.id}`}
          ctaLabel="Ver drop"
          ctaVariant="primary"
        >
          <p><strong>{entry.data.price}</strong></p>
        </CollectionCard>
      ))}
    </div>
  </section>
</PageShell>
