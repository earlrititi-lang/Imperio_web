---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const drops = await getCollection("drops");
const sorted = drops.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout
  title="Tienda | Imperioes"
  description="Drops editoriales de tirada corta y piezas de archivo."
>
  <div class="container">
    <section class="section">
      <span class="pill">Tienda</span>
      <h1>Drops editoriales</h1>
      <p>
        Tiradas cortas, calidad sobria, sin ruido. Checkout seguro con Stripe.
      </p>
    </section>

    <section class="section">
      <div class="grid">
        {sorted.map((entry) => (
          <article class="card">
            <p class="muted">
              {entry.data.status} - {entry.data.date}
            </p>
            <h3>{entry.data.title}</h3>
            <p>{entry.data.summary}</p>
            <p><strong>{entry.data.price}</strong></p>
            <a class="btn btn-primary" href={`/tienda/${entry.slug}`}>
              Ver drop
            </a>
          </article>
        ))}
      </div>
    </section>
  </div>
</Layout>

