---
// src/pages/index.astro
// Página principal completa integrando todos los componentes

import Layout from '../layouts/Layout.astro';
import Preloader from '../components/Preloader.jsx';
import Navigation from '../components/Navigation.jsx';
import HeroImperio from '../components/HeroImperio.jsx';
import FastCarousel from '../components/FastCarousel.jsx';
import Services from '../components/Services.jsx';
import ProjectsGrid from '../components/ProjectsGrid.jsx';
import Footer from '../components/Footer.jsx';
---

<Layout title="El Siglo Español - Arquitectura y Diseño">
  <Preloader client:load />
  <Navigation client:load />
  <HeroImperio client:load />
  <FastCarousel client:load />
  <Services client:load />
  <ProjectsGrid client:load />
  <Footer client:load />
</Layout>

<style is:global>
  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Personalización del scrollbar (opcional, estilo elegante) */
  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: #f1f1f1;
  }

  ::-webkit-scrollbar-thumb {
    background: #000;
    border-radius: 5px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-red-accent);
  }
</style>
