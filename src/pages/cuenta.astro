---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Cuenta | Imperioes"
  description="Gestiona tu acceso, suscripcion y perfil."
>
  <div class="container">
    <section class="section content">
      <span class="pill">Cuenta</span>
      <h1>Tu acceso</h1>
      <p class="muted">ASUNCION: login y membresia se integran en Sprint 3.</p>
      <div class="grid">
        <div class="card">
          <h3>Suscripcion</h3>
          <p>Gestiona nivel, facturas y metodo de pago.</p>
        </div>
        <div class="card">
          <h3>Perfil</h3>
          <p>Preferencias, notificaciones y acceso a Discord.</p>
        </div>
      </div>
      <div class="section">
        <a class="btn btn-primary" href="/login">Iniciar sesion</a>
      </div>
    </section>
  </div>
</Layout>

