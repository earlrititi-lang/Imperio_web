---
// src/components/Hero.astro
// Hero con texto animado grande (replica exacta de studioDSK)
---

<section class="hero-section min-h-screen flex items-center justify-center relative overflow-hidden bg-white pt-24">
  <!-- 
    IMAGEN NECESARIA: Imagen de fondo sutil del Siglo de Oro
    Sugerencias: Mapa antiguo de España, textura de pergamino, o arquitectura colonial
    Formato: JPG de alta calidad
    Dimensiones: 1920x1080px mínimo
    Ubicación: /public/images/hero-bg.jpg
    Nota: Se aplicará con opacidad baja para no competir con el texto
  -->
  <div class="hero-bg absolute inset-0 opacity-5">
    <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover" />
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <h1 class="hero-title text-center">
      <span class="hero-line block overflow-hidden">
        <span class="hero-word">DISEÑO</span>
      </span>
      <span class="hero-line block overflow-hidden">
        <span class="hero-word">CONSULTORÍA</span>
      </span>
      <span class="hero-line block overflow-hidden">
        <span class="hero-word">PLANIFICACIÓN</span>
      </span>
      <span class="hero-line block overflow-hidden">
        <span class="hero-word">ARQUITECTURA</span>
      </span>
      <span class="hero-line block overflow-hidden">
        <span class="hero-word">INTERIORES</span>
      </span>
    </h1>

    <div class="hero-subtitle mt-12 max-w-4xl mx-auto text-center opacity-0">
      <p class="text-xl md:text-2xl leading-relaxed">
        El Siglo Español diseña ambientes que conectan personas, lugares y propósitos. 
        Desde residencias atemporales hasta proyectos emblemáticos, nuestro trabajo forja un impacto duradero.
      </p>
    </div>

    <!-- Botones CTA -->
    <div class="hero-cta mt-12 flex flex-wrap gap-6 justify-center opacity-0">
      <a href="/obras" class="cta-button cta-primary">
        <span>Ver Obras</span>
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="/estudio" class="cta-button cta-secondary">
        <span>Nuestro Estudio</span>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator absolute bottom-12 left-1/2 -translate-x-1/2 opacity-0">
      <div class="w-6 h-10 border-2 border-black rounded-full flex justify-center pt-2">
        <div class="w-1 h-3 bg-black rounded-full animate-scroll"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-title {
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .hero-word {
    display: inline-block;
    transform: translateY(100%);
    opacity: 0;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
    border: 2px solid;
  }

  .cta-primary {
    background: var(--color-accent);
    color: white;
    border-color: var(--color-accent);
  }

  .cta-primary:hover {
    background: transparent;
    color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(220, 38, 38, 0.3);
  }

  .cta-secondary {
    background: transparent;
    color: black;
    border-color: black;
  }

  .cta-secondary:hover {
    background: black;
    color: white;
    transform: translateY(-2px);
  }

  @keyframes scroll {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    50% {
      opacity: 1;
    }
    100% {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  .animate-scroll {
    animation: scroll 2s ease-in-out infinite;
  }
</style>

<script>
  // Animación de aparición del hero (gsap-like con vanilla JS)
  document.addEventListener('DOMContentLoaded', () => {
    const heroWords = document.querySelectorAll('.hero-word');
    const subtitle = document.querySelector('.hero-subtitle');
    const cta = document.querySelector('.hero-cta');
    const scrollIndicator = document.querySelector('.scroll-indicator');

    // Animar palabras del título
    heroWords.forEach((word, index) => {
      setTimeout(() => {
        word.style.transition = 'transform 1s cubic-bezier(0.76, 0, 0.24, 1), opacity 1s ease';
        word.style.transform = 'translateY(0)';
        word.style.opacity = '1';
      }, index * 150);
    });

    // Animar subtítulo
    setTimeout(() => {
      subtitle.style.transition = 'opacity 1s ease';
      subtitle.style.opacity = '1';
    }, heroWords.length * 150 + 300);

    // Animar CTAs
    setTimeout(() => {
      cta.style.transition = 'opacity 1s ease';
      cta.style.opacity = '1';
    }, heroWords.length * 150 + 600);

    // Animar scroll indicator
    setTimeout(() => {
      scrollIndicator.style.transition = 'opacity 1s ease';
      scrollIndicator.style.opacity = '1';
    }, heroWords.length * 150 + 900);
  });
</script>
